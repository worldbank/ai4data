# Copy to .env and fill in the keys for the provider you use.
# Only needed for `pift generate` against a hosted LLM; the rest of the
# pipeline (mine, finetune, evaluate, search) needs no API key.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: needed only if you push fine-tuned models to the Hugging Face Hub.
HF_TOKEN=
